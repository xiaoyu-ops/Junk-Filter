# JunkFilter 环境变量配置示例
# 使用方法：复制此文件为 .env，然后填入实际的敏感值
# cp .env.example .env

# ========== 数据库配置 ==========
DB_HOST=localhost
DB_PORT=5432
DB_USER=truesignal
DB_PASSWORD=CHANGE_ME_DATABASE_PASSWORD
DB_NAME=truesignal
DB_SSL_MODE=disable  # 开发环境；生产改为 require

# ========== Redis 配置 ==========
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_32_CHARS_MIN

# ========== CORS 配置（严格模式）==========
# 开发环境：允许前端本地访问
# 生产环境：改为您的前端域名（如 https://yourapp.com）
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization
CORS_ALLOW_CREDENTIALS=false

# ========== 日志配置 ==========
LOG_LEVEL=INFO

# ========== LLM 配置（OpenAI 兼容）==========
# 重要：为了启用 AI Agent 聊天功能，请设置真实的 OPENAI_API_KEY
#
# 选项 1: 使用 OpenAI 官方 API
# 获取方式: https://platform.openai.com/api-keys
# 注意：需要绑定支付方式，按使用量计费
OPENAI_API_KEY=sk-CHANGE_ME_REAL_OPENAI_API_KEY

# 选项 2: 使用中转站（推荐用于测试）
# 中转站地址: https://elysiver.h-e.top/v1
LLM_BASE_URL=https://elysiver.h-e.top/v1
LLM_MODEL_ID=gpt-4o

# 可选：使用其他 LLM 提供商
#
# DeepSeek 配置
# DEEPSEEK_API_KEY=sk-CHANGE_ME
# LLM_MODEL_ID=deepseek-chat
#
# 阿里云通义配置
# DASHSCOPE_API_KEY=CHANGE_ME
# LLM_MODEL_ID=qwen-plus

# ========== Go 后端配置 ==========
GO_SERVER_PORT=8080
PYTHON_API_URL=http://localhost:8081

# ========== Python 后端配置（可选）==========
API_PORT=8081
